# =============================================================================
# NovelSolar — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit your actual .env file to version control.
#
# Variables marked [REQUIRED] must be set for the app to function.
# Variables marked [OPTIONAL] have sensible defaults or enable extra features.
# =============================================================================


# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# [REQUIRED] Public base URL used for magic-link redirects and canonical URLs.
# Use http://localhost:3000 for local dev, or your live domain in production.
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# [OPTIONAL] WhatsApp contact number (override for staging/dev).
NUXT_PUBLIC_WHATSAPP_NUMBER=
NUXT_PUBLIC_WHATSAPP_NUMBER_FORMATTED=


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# [REQUIRED] Your Supabase project URL.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# [REQUIRED] Supabase anon (public) key — safe to expose to the browser.
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service-role key — server-side only, never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=

# [REQUIRED] Supabase JWT secret — used to verify signed tokens server-side.
SUPABASE_JWT_SECRET=


# -----------------------------------------------------------------------------
# Postgres (Direct / Pooled connections via Supabase)
# -----------------------------------------------------------------------------

# [REQUIRED] Database name (usually "postgres").
POSTGRES_DATABASE=postgres

# [REQUIRED] Direct database host.
POSTGRES_HOST=db.<your-project-ref>.supabase.co

# [REQUIRED] Database user.
POSTGRES_USER=postgres

# [REQUIRED] Database password.
POSTGRES_PASSWORD=

# [REQUIRED] Pooled connection string (used by Prisma / pgBouncer, port 6543).
POSTGRES_PRISMA_URL=

# [REQUIRED] Pooled connection string (port 6543, Supabase pooler).
POSTGRES_URL=

# [REQUIRED] Non-pooled (direct) connection string (port 5432) — used for migrations.
POSTGRES_URL_NON_POOLING=


# -----------------------------------------------------------------------------
# SMTP / Email (Brevo / SendGrid or any SMTP provider)
# -----------------------------------------------------------------------------

# [REQUIRED] SMTP relay host.
SMTP_HOST=smtp-relay.brevo.com

# [REQUIRED] SMTP port (587 for STARTTLS, 465 for SSL).
SMTP_PORT=587

# [REQUIRED] SMTP authentication username.
SMTP_USER=

# [REQUIRED] SMTP authentication password / API key.
SMTP_PASS=

# [REQUIRED] "From" address shown on outgoing emails.
# Format: "Display Name <email@example.com>"
SMTP_FROM=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] Secret used to sign and verify OTP tokens.
# Generate with: openssl rand -base64 64
OTP_SECRET=

# [REQUIRED] Secret used to sign admin session cookies.
# Generate with: openssl rand -base64 64
AUTH_SESSION_SECRET=


# -----------------------------------------------------------------------------
# Bitrix24 CRM
# -----------------------------------------------------------------------------

# [REQUIRED] Bitrix24 inbound webhook URL (used for product/lead syncing).
BITRIX_WEBHOOK_URL=https://<your-domain>.bitrix24.com/rest/<user-id>/<webhook-token>/


# -----------------------------------------------------------------------------
# Cloudinary (Product Image Uploads)
# -----------------------------------------------------------------------------

# [REQUIRED] Your Cloudinary cloud name.
CLOUDINARY_CLOUD_NAME=

# [REQUIRED] Cloudinary API key.
CLOUDINARY_API_KEY=

# [REQUIRED] Cloudinary API secret — server-side only.
CLOUDINARY_API_SECRET=


# -----------------------------------------------------------------------------
# Blog Manager (GitHub Contents API)
# -----------------------------------------------------------------------------

# [REQUIRED] Fine-grained personal access token with contents read/write access
# to the blog repository. Used to commit content/blog/*.md changes from the
# admin UI. Without this, the Blog Manager save/delete endpoints will fail.
BLOG_GITHUB_TOKEN=

# [OPTIONAL] Repository owner (defaults to dev-davies).
BLOG_GITHUB_OWNER=dev-davies

# [OPTIONAL] Repository name (defaults to NovelSolar).
BLOG_GITHUB_REPO=NovelSolar

# [OPTIONAL] Branch to commit blog changes to (defaults to master).
BLOG_GITHUB_BRANCH=master


# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------

# [OPTIONAL] Passcode required to trigger the admin product-upload flow.
# Leave blank to disable the passcode gate.
ADMIN_UPLOAD_PASSCODE=


# -----------------------------------------------------------------------------
# Vercel KV (Redis) — Production Session / OTP Storage
# -----------------------------------------------------------------------------
# When KV_REST_API_URL is set in a production environment, Nitro storage
# drivers for 'otp', 'adminSessions', and 'userSessions' switch from
# in-memory to Vercel KV automatically. Not needed for local development.

# [OPTIONAL] Vercel KV REST API URL (auto-injected when KV is linked on Vercel).
KV_REST_API_URL=

# [OPTIONAL] Vercel KV REST API token.
KV_REST_API_TOKEN=

# Legacy Redis URL (used if not on Vercel KV).
# [OPTIONAL] redis://default:<password>@<host>:<port>
REDIS_URL=


# -----------------------------------------------------------------------------
# Error Logging Webhook
# -----------------------------------------------------------------------------
# These enable server-side error forwarding to an external logging service
# (e.g. a Discord / Slack webhook or a custom endpoint).

# [OPTIONAL] Full URL of the error-logging webhook endpoint.
ERROR_LOGGING_WEBHOOK_URL=

# [OPTIONAL] HTTP Authorization header value sent with each log request.
ERROR_LOGGING_WEBHOOK_AUTH_HEADER=

# [OPTIONAL] Bearer token for the error-logging webhook.
ERROR_LOGGING_WEBHOOK_TOKEN=

# [OPTIONAL] Set to "false" to disable client-side error logging.
NUXT_PUBLIC_ERROR_LOGGING_ENABLED=true

# [OPTIONAL] Client-side endpoint that proxies errors to the webhook (default: /api/log-error).
NUXT_PUBLIC_ERROR_LOGGING_ENDPOINT=/api/log-error
